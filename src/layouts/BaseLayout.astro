---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { DEFAULT_EDITION, pagePath } from '../lib/editions';
import type { Edition } from '../lib/editions';
import { SITE } from '../lib/site';
import '../styles/global.css';

interface Props {
  edition: Edition;
  /** null/undefined = homepage. Ignored when pathOverride is set. */
  slug?: string | null;
  /** absolute path for bespoke pages (about / editorial-standards / medical-disclaimer). */
  pathOverride?: string;
  /** editions in which THIS exact page exists (for hreflang). Defaults to [edition]. */
  presentEditions?: Edition[];
  title: string;
  /** when true, use `title` verbatim as <title> (homepages); else append "| Brand". */
  rawTitle?: boolean;
  description: string;
  jsonLd?: Record<string, any>[];
  ogType?: string;
  /** per-page OG/social image (absolute path); falls back to SITE.ogImage. */
  image?: string;
}

const {
  edition, slug = null, pathOverride, presentEditions,
  title, rawTitle = false, description, jsonLd = [], ogType = 'website', image,
} = Astro.props;

const abs = (p: string) => new URL(p, Astro.site).href;
const ogImage = image ?? SITE.ogImage;
const ogImageAbs = ogImage ? abs(ogImage) : '';
const canonicalPath = pathOverride ?? pagePath(edition, slug);
const canonical = abs(canonicalPath);

// hreflang: bidirectional, every edition where this page exists, plus x-default -> root English.
const present = presentEditions ?? [edition];
const alternates = pathOverride
  ? [{ hreflang: edition.hreflang, href: canonical }]
  : present.map((e) => ({ hreflang: e.hreflang, href: abs(pagePath(e, slug)) }));
const xDefaultHref = pathOverride ? canonical : abs(pagePath(DEFAULT_EDITION, slug));

const fullTitle = rawTitle ? title : `${title} | ${SITE.name}`;
const ogLocale = edition.hreflang.replace(/-/g, '_');

// BreadcrumbList — derived from page identity so every non-home page gets a valid trail
// (Home > current). Home crumb = this edition's own homepage; publisher stays SITE.name.
const isHome = slug == null && !pathOverride;
const breadcrumbLd = isHome ? null : {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: SITE.name, item: abs(pagePath(edition, null)) },
    { '@type': 'ListItem', position: 2, name: title, item: canonical },
  ],
};
---
<!doctype html>
<html lang={edition.hreflang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- hreflang: all editions of this page + x-default -> root English (Google i18n best practice) -->
    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- Open Graph / social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={ogLocale} />
    {ogImageAbs && <meta property="og:image" content={ogImageAbs} />}
    <meta name="twitter:card" content="summary_large_image" />
    {ogImageAbs && <meta name="twitter:image" content={ogImageAbs} />}

    <!-- Organization structured data — the publisher entity for AI engines -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: SITE.name,
      url: SITE.domain,
      description: SITE.orgDescription,
      foundingDate: String(SITE.foundingYear),
      knowsAbout: SITE.knowsAbout,
      publishingPrinciples: abs('/editorial-standards/'),
    })} />

    <!-- WebSite structured data — site-level entity for search + AI engines -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: SITE.name,
      url: SITE.domain,
      inLanguage: edition.hreflang,
      publisher: { '@type': 'Organization', name: SITE.name, url: SITE.domain },
    })} />

    {breadcrumbLd && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    )}

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <Header edition={edition} />
    <main>
      <slot />
    </main>
    <Footer edition={edition} slug={slug} presentEditions={present} pathOverride={pathOverride} />
  </body>
</html>
