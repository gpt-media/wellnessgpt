---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Structured data objects (schema.org) injected as JSON-LD - the AIO backbone. */
  jsonLd?: Record<string, any>[];
  ogType?: string;
  /** Page path (e.g. '/', '/about/', '/articles/foo/'); reserved for future hreflang. */
  path?: string;
}

const { title, description, jsonLd = [], ogType = 'website' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const fullTitle = title === 'TheWellnessGPT'
  ? 'TheWellnessGPT: Smarter answers for how you feel'
  : `${title} | TheWellnessGPT`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="TheWellnessGPT" />
    <meta property="og:locale" content="en" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Organization structured data - establishes the publisher entity for AI engines -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'TheWellnessGPT',
      url: 'https://thewellnessgpt.com',
      description: 'Evidence-led wellness answers for a global audience.',
    })} />

    {jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
