---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const all = (await getCollection('articles-sg-ms')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('ms-SG', { year: 'numeric', month: 'short', day: 'numeric' });

const PILLARS = new Set(['best-acne-patches-singapore-2026', 'how-to-treat-acne-singapore']);
const PATCHES = new Set([
  'best-acne-patches-singapore-2026', 'hydrocolloid-vs-microneedle-acne-patches', 'do-pimple-patches-work-overnight',
  'how-long-to-leave-a-pimple-patch-on', 'how-microneedle-acne-patches-work', 'where-do-acne-patches-fit-skincare-routine',
  'best-patch-for-cystic-under-skin-acne-singapore', 'best-acne-patches-oily-skin-singapore', 'best-acne-patches-sensitive-skin',
  'best-acne-patches-for-teens-singapore', 'acne-patches-for-maskne-singapore', 'salicylic-acid-patches-vs-hydrocolloid',
  'korean-vs-western-acne-patches', 'where-to-buy-acne-patches-singapore-price-guide', 'how-to-spot-fake-hydrocolloid-patch',
  'can-you-wear-pimple-patches-under-makeup', 'are-pimple-patches-safe', 'do-acne-patches-leave-marks-or-scars',
  'pimple-patch-not-sticking-fixes', 'pimple-patches-vs-popping', 'do-acne-patches-work-on-blackheads-whiteheads',
]);

const pillars = all.filter((a) => PILLARS.has(a.slug));
const patches = all.filter((a) => PATCHES.has(a.slug) && !PILLARS.has(a.slug));
const treatment = all.filter((a) => !PATCHES.has(a.slug) && !PILLARS.has(a.slug));

const sections = [
  { title: 'Mulakan di sini', items: pillars },
  { title: 'Patch Jerawat', items: patches },
  { title: 'Rawatan & Bahan', items: treatment },
];
---
<BaseLayout
  title="Jawapan penjagaan kulit untuk kulit Singapura"
  description="Jawapan berasaskan bukti untuk soalan penjagaan kulit anda, dibina untuk kulit Singapura. Perbandingan jelas, mekanisme sebenar, dan apa yang betul-betul berkesan."
  lang="ms" market="sg"
  path="/"
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Penjagaan kulit, dihuraikan</p>
      <h1 class="tagline">Jawapan lebih bijak untuk kulit anda.</h1>
      <p>Panduan penjagaan kulit berasaskan bukti untuk kulit Singapura: jerawat, patch, parut hitam, dan apa yang betul-betul berkesan. Perbandingan jelas, mekanisme sebenar, harga dalam dolar Singapura.</p>
    </div>
  </section>

  <div class="wrap">
    {sections.map((section) => section.items.length > 0 && (
      <section class="cluster">
        <h2 class="section-title">{section.title}</h2>
        <ul class="article-list">
          {section.items.map((a) => (
            <li>
              <a class="title" href={`/sg/ms/articles/${a.slug}/`}>{a.data.title}</a>
              <p>{a.data.description}</p>
              <span class="meta">{a.data.category} · {fmt(a.data.publishDate)}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
