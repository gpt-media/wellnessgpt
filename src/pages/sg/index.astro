---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = (await getCollection('articles-sg')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('en-SG', { year: 'numeric', month: 'short', day: 'numeric' });

const PILLARS = new Set(['best-acne-patches-singapore-2026', 'how-to-treat-acne-singapore']);
const MY_PATCHES = [
  'best-acne-patches-malaysia-2026', 'hydrocolloid-vs-microneedle-acne-patches', 'do-pimple-patches-work-overnight',
  'how-long-to-leave-a-pimple-patch-on', 'how-microneedle-acne-patches-work', 'where-do-acne-patches-fit-skincare-routine',
  'best-patch-for-cystic-under-skin-acne-malaysia', 'best-acne-patches-oily-skin-malaysia', 'best-acne-patches-sensitive-skin',
  'best-acne-patches-for-teens-malaysia', 'acne-patches-for-maskne-malaysia', 'salicylic-acid-patches-vs-hydrocolloid',
  'korean-vs-western-acne-patches', 'where-to-buy-acne-patches-malaysia-price-guide', 'how-to-spot-fake-hydrocolloid-patch',
  'can-you-wear-pimple-patches-under-makeup', 'are-pimple-patches-safe', 'do-acne-patches-leave-marks-or-scars',
  'pimple-patch-not-sticking-fixes', 'pimple-patches-vs-popping', 'do-acne-patches-work-on-blackheads-whiteheads',
];
const PATCHES = new Set(MY_PATCHES.map((s) => s.replace('malaysia', 'singapore')));

const pillars = all.filter((a) => PILLARS.has(a.slug));
const patches = all.filter((a) => PATCHES.has(a.slug) && !PILLARS.has(a.slug));
const treatment = all.filter((a) => !PATCHES.has(a.slug) && !PILLARS.has(a.slug));

const sections = [
  { title: 'Start here', items: pillars },
  { title: 'Acne Patches', items: patches },
  { title: 'Treatment & Ingredients', items: treatment },
];
---
<BaseLayout
  title="TheWellnessGPT"
  description="Evidence-led answers to your skincare questions, built for skin in Singapore. Clear comparisons, real mechanisms, and what actually works."
  lang="en"
  market="sg"
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Skincare, decoded</p>
      <h1 class="tagline">Smarter answers for your skin.</h1>
      <p>Evidence-led skincare guidance for Singapore: acne, patches, dark spots, and what actually works. Clear comparisons, real mechanisms, prices in SGD.</p>
    </div>
  </section>

  <div class="wrap">
    {sections.map((section) => section.items.length > 0 && (
      <section class="cluster">
        <h2 class="section-title">{section.title}</h2>
        <ul class="article-list">
          {section.items.map((a) => (
            <li>
              <a class="title" href={`/sg/articles/${a.slug}/`}>{a.data.title}</a>
              <p>{a.data.description}</p>
              <span class="meta">{a.data.category} · {fmt(a.data.publishDate)}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
