---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const all = (await getCollection('articles')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
const fmt = (d: Date) => d.toLocaleDateString('en-MY', { year: 'numeric', month: 'short', day: 'numeric' });

// Hub-and-spoke: featured pillars surface first ("Start here"), then everything
// groups by category. Category-driven so new clusters slot in without code changes.
const pillars = all.filter((a) => a.data.featured);
const rest = all.filter((a) => !a.data.featured);
const categories = [...new Set(rest.map((a) => a.data.category))];
const sections = [
  { title: 'Start here', items: pillars },
  ...categories.map((c) => ({ title: c, items: rest.filter((a) => a.data.category === c) })),
];
---
<BaseLayout
  title="TheWellnessGPT"
  description="Evidence-led answers to your wellness questions, built for life in Malaysia. Clear comparisons, real mechanisms, and what actually works."
  path="/"
>
  <section class="hero">
    <div class="wrap">
      <p class="kicker">Wellness, decoded</p>
      <h1 class="tagline">Smarter answers for how you feel.</h1>
      <p>Evidence-led wellness guidance for life in Malaysia: supplements, gut health, sleep, energy, and what actually works. Clear comparisons, real mechanisms, prices in ringgit.</p>
    </div>
  </section>

  <div class="wrap">
    {sections.map((section) => section.items.length > 0 && (
      <section class="cluster">
        <h2 class="section-title">{section.title}</h2>
        <ul class="article-list">
          {section.items.map((a) => (
            <li>
              <a class="title" href={`/my/articles/${a.slug}/`}>{a.data.title}</a>
              <p>{a.data.description}</p>
              <span class="meta">{a.data.category} · {fmt(a.data.publishDate)}</span>
            </li>
          ))}
        </ul>
      </section>
    ))}
    {all.length === 0 && <p>First answers publishing soon.</p>}
  </div>
</BaseLayout>
