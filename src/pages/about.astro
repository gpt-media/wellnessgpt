---
import BaseLayout from '../layouts/BaseLayout.astro';
import { DEFAULT_EDITION } from '../lib/editions';
import { SITE } from '../lib/site';

const abs = (p: string) => new URL(p, Astro.site).href;
// AboutPage + Organization (the publisher entity) — the E-E-A-T surface AI engines read to
// decide who is behind these YMYL health answers and what they're expert in.
const aboutLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: `About ${SITE.name}`,
    url: abs('/about/'),
    mainEntity: {
      '@type': 'Organization',
      name: SITE.name,
      url: SITE.domain,
      description: SITE.orgDescription,
      foundingDate: String(SITE.foundingYear),
      knowsAbout: SITE.knowsAbout,
      publishingPrinciples: abs('/editorial-standards/'),
    },
  },
];
---
<BaseLayout
  edition={DEFAULT_EDITION}
  pathOverride="/about/"
  title="About"
  description="TheWellnessGPT gives evidence-led wellness answers: clear comparisons, real mechanisms, and guidance you can act on, wherever you are."
  jsonLd={aboutLd}
>
  <article class="article">
    <div class="wrap">
      <p class="kicker">About</p>
      <h1>Wellness, decoded.</h1>
      <div class="article-body">
        <p>TheWellnessGPT answers one question well: <em>what actually works for my health?</em> Most wellness content online is vague, hyped, or quietly selling you something. We give clear, evidence-led answers you can act on.</p>

        <h2>How we work</h2>
        <ul>
          <li><strong>Mechanism and evidence first.</strong> We explain <em>why</em> something works (or doesn't), and how strong the evidence actually is, before we get to any product.</li>
          <li><strong>Real comparisons.</strong> We weigh the actual options on the same terms, and tell you when a cheaper one, or whole food, wins.</li>
          <li><strong>No hype.</strong> When the honest answer is "you don't need this," we say so.</li>
        </ul>

        <h2>Who writes and reviews this</h2>
        <p>Our articles are researched and written by the <strong>{SITE.author.name}</strong> — a research-led team that reads the primary literature (clinical trials, systematic reviews, and guidance from bodies like the NHS, NIH, and registered-dietitian sources) and translates it into plain English. We grade how strong the evidence actually is — strong, mixed, or preliminary — rather than presenting everything as settled.</p>
        <p>Every health article is checked against our <a href="/editorial-standards/">editorial standards</a>: mechanism explained, evidence graded honestly, sources real and cited, and no claim stretched beyond what the research supports. When the honest answer is "the evidence is weak" or "you don't need this," we say so.</p>

        <h2>Not medical advice</h2>
        <p>Our content is educational. For persistent or worsening symptoms, or before starting a new supplement, see a doctor or pharmacist.</p>
      </div>
    </div>
  </article>
</BaseLayout>
