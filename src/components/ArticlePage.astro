---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Newsletter from './Newsletter.astro';
import Related from './Related.astro';
import type { Edition } from '../lib/editions';
import { pagePath } from '../lib/editions';
import { SITE, UI } from '../lib/site';

interface Props {
  edition: Edition;
  entry: CollectionEntry<'articles'>;
  slug: string;
  presentEditions?: Edition[];
}
const { edition, entry, slug, presentEditions } = Astro.props;
const { Content } = await entry.render();
const d = entry.data;
const t = UI[edition.ui];
const fmt = (dt: Date) => dt.toLocaleDateString(t.dateLocale, { year: 'numeric', month: 'long', day: 'numeric' });
const url = new URL(pagePath(edition, slug), Astro.site).href;
const abs = (p: string) => new URL(p, Astro.site).href;
const imageAbs = d.image ? abs(d.image) : (SITE.ogImage ? abs(SITE.ogImage) : '');

// Named credentialed reviewer (E-E-A-T for YMYL health content). Dormant until SITE.reviewer
// is set to a REAL reviewer — never fabricated. When present it adds reviewedBy + lastReviewed.
const reviewedBy = SITE.reviewer
  ? { '@type': 'Person', name: SITE.reviewer.name, jobTitle: SITE.reviewer.credential, ...(SITE.reviewer.url ? { url: SITE.reviewer.url } : {}) }
  : null;

// ISO date this answer was last reviewed/updated (falls back to publish date).
const lastReviewed = (d.updatedDate ?? d.publishDate).toISOString();

// Citations — surface the external evidence the prose cites as machine-readable WebPage refs
// (strong AI-citation + E-E-A-T signal). Auto-extract markdown links from the raw body, KEEP
// only EXTERNAL absolute http(s) URLs: drop relative (/articles/…) and self-domain links so we
// only expose third-party sources (NIH/PMC/Cochrane/Mayo/…). Dedupe, preserve first-seen order.
const selfHost = (() => {
  try { return new URL(SITE.domain).hostname.replace(/^www\./, ''); } catch { return ''; }
})();
const citationUrls = (() => {
  const seen = new Set<string>();
  const out: string[] = [];
  const re = /\]\((https?:\/\/[^)\s]+)\)/g;
  let m: RegExpExecArray | null;
  while ((m = re.exec(entry.body)) !== null) {
    const u = m[1];
    let host = '';
    try { host = new URL(u).hostname.replace(/^www\./, ''); } catch { continue; }
    if (selfHost && (host === selfHost || host.endsWith('.' + selfHost))) continue; // drop self-domain
    if (seen.has(u)) continue;
    seen.add(u);
    out.push(u);
  }
  return out;
})();

// Article structured data — a citeable, dated, authored answer for AI engines.
const articleSchema: Record<string, any> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  // Flags this as a medical/health page (YMYL) without naming a reviewer that doesn't exist.
  additionalType: 'https://schema.org/MedicalWebPage',
  headline: d.title,
  description: d.description,
  datePublished: d.publishDate.toISOString(),
  dateModified: (d.updatedDate ?? d.publishDate).toISOString(),
  lastReviewed,
  author: { '@type': 'Organization', name: SITE.author.name, url: SITE.author.url },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.domain },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  publishingPrinciples: abs('/editorial-standards/'),
  inLanguage: edition.hreflang,
  ...(imageAbs ? { image: { '@type': 'ImageObject', url: imageAbs } } : {}),
  ...(citationUrls.length ? { citation: citationUrls.map((u) => ({ '@type': 'WebPage', url: u })) } : {}),
  // Entity substrate (about + mentions). Lights up only when `entities` frontmatter is populated;
  // omitted entirely when absent. NOT backfilled here — purely the rendering wiring.
  ...(d.entities?.length ? { about: d.entities.map((e) => ({ '@type': 'Thing', name: e })) } : {}),
  ...(d.entities?.length ? { mentions: d.entities.map((e) => ({ '@type': 'Thing', name: e })) } : {}),
  ...(reviewedBy ? { reviewedBy } : {}),
};
// FAQPage structured data — the highest-value schema for getting pulled into AI answers.
const faqSchema = d.faqs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      inLanguage: edition.hreflang,
      mainEntity: d.faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
const jsonLd = faqSchema ? [articleSchema, faqSchema] : [articleSchema];
---
<BaseLayout
  edition={edition}
  slug={slug}
  presentEditions={presentEditions}
  title={d.title}
  description={d.description}
  jsonLd={jsonLd}
  ogType="article"
  image={d.image}
>
  <article class="article">
    <div class="wrap">
      <p class="kicker">{d.category}</p>
      <h1>{d.title}</h1>
      <p class="meta">
        {t.metaBy} <a href={SITE.author.url} rel="author">{d.author}</a>
        {SITE.reviewer && <> · {t.metaReviewed} {SITE.reviewer.name}, {SITE.reviewer.credential}</>}
        · {t.metaPublished} {fmt(d.publishDate)}
        {d.updatedDate && <> · {t.metaUpdated} {fmt(d.updatedDate)}</>}
      </p>

      {/* AEO: a liftable, direct answer up top — the exact shape AI engines quote. */}
      <div class="quick-answer">
        <p class="qa-label">{t.quickAnswer}</p>
        <p>{d.description}</p>
      </div>

      <div class="article-body">
        <Content />
      </div>

      {d.faqs.length > 0 && (
        <section class="faq">
          <h2>{t.faqHeading}</h2>
          {d.faqs.map((f) => (
            <details>
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </section>
      )}

      <Related edition={edition} entry={entry} />

      <Newsletter edition={edition} />
    </div>
  </article>
</BaseLayout>
