---
import type { Edition } from '../lib/editions';
import { pagePath } from '../lib/editions';
import { SITE, UI } from '../lib/site';

interface Props { edition: Edition; }
const { edition } = Astro.props;
const t = UI[edition.ui];
const homeHref = pagePath(edition); // Home nav stays within the current edition
const rootHref = '/'; // logo always points to the global x-default home
---
<header class="site-header">
  <div class="wrap">
    <a href={rootHref} class="logo">{SITE.logo.pre}<span>{SITE.logo.accent}</span>{SITE.logo.post}</a>
    <nav>
      <a href={homeHref}>{t.navHome}</a>
      {/* Reports are global, English-only (/reports/<slug>/) — surfaced only on the
          x-default edition, mirroring the homepage's Reports section gating. */}
      {edition.isDefault && <a href="/reports/state-of-supplements-2026/">Reports</a>}
      <a href="/about/">{t.navAbout}</a>
    </nav>
  </div>
</header>
