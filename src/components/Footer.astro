---
import type { Edition } from '../lib/editions';
import { editionsByCountry, pagePath } from '../lib/editions';
import { SITE, UI } from '../lib/site';

interface Props {
  edition: Edition;
}
const { edition } = Astro.props;
const t = UI[edition.ui];
const year = 2026;

// Region/language switcher lives in the footer (clean, authority-style header; hreflang does
// the search-engine routing). No auto-redirect — the reader chooses. Compact zero-JS
// <details> disclosure: collapsed to one line by default, links remain in the DOM (crawlable).
// Each link points to the target edition's HOMEPAGE (never per-page alternates), so the
// switcher can never 404 on pages that exist in only some editions (e.g. /reports/).
const groups = editionsByCountry();
---
<footer class="site-footer">
  <div class="wrap">
    <nav class="footer-nav">
      <a href="/about/">{t.navAbout}</a>
      <a href="/editorial-standards/">{t.footerEditorial}</a>
      <a href="/how-we-review/">{t.footerHowWeReview}</a>
      <a href="/medical-disclaimer/">{t.footerDisclaimer}</a>
      <a href="/privacy/">{t.footerPrivacy}</a>
    </nav>
    <details class="lang-switch">
      <summary aria-label={t.pickerLabel}><span class="ls-globe" aria-hidden="true">🌐</span> {t.footerLanguage}</summary>
      <ul class="ls-list">
        {groups.map((g) => (
          <li>
            <span class="ls-region"><span class="ls-flag" aria-hidden="true">{g.flag}</span> {g.country}</span>
            <span class="ls-langs">
              {g.editions.map((e, i) => (
                <>
                  {i > 0 && <span class="ls-sep">·</span>}
                  {e.key === edition.key
                    ? <span class="on" aria-current="true">{e.langLabel}</span>
                    : <a href={pagePath(e)}>{e.langLabel}</a>}
                </>
              ))}
            </span>
          </li>
        ))}
      </ul>
    </details>
    <p class="fineprint">{t.disclaimerLine}</p>
    <p class="fineprint">&copy; {year} {SITE.name}. {t.rights}</p>
  </div>
</footer>
