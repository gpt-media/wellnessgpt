---
import type { Edition } from '../lib/editions';
import { SITE, UI } from '../lib/site';

interface Props { edition: Edition; }
const { edition } = Astro.props;
const t = UI[edition.ui];
const year = 2026;
---
<footer class="site-footer">
  <div class="wrap">
    <nav class="footer-nav">
      <a href="/about/">{t.navAbout}</a>
      <a href="/editorial-standards/">{t.footerEditorial}</a>
      <a href="/medical-disclaimer/">{t.footerDisclaimer}</a>
    </nav>
    <p class="fineprint">{t.disclaimerLine}</p>
    <p class="fineprint">&copy; {year} {SITE.name}. {t.rights}</p>
  </div>
</footer>
